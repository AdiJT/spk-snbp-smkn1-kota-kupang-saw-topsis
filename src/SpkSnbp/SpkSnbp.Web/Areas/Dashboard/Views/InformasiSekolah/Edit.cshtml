@using SpkSnbp.Web.Areas.Dashboard.Models.InformasiSekolahModels

@model EditVM

@{
    ViewData["Title"] = "Edit Informasi Umum";
}

<!-- Breadcrumb -->
<div class="row">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="#">Profil</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Informasi Umum</a></li>
            <li class="breadcrumb-item" aria-current="page">Edit</li>
        </ol>
    </nav>
</div>

<div class="section-body">
    <div class="row" style="justify-content: center;">
        <div class="col-12 col-md-12 col-lg-12">
            <div class="card card-warning">

                <div class="card-header" style="padding-top: 20px;">
                    <h4>Informasi Umum SMKN 1 Kota Kupang</h4>
                </div>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">

                    <div class="card-body d-flex flex-column">

                        <div asp-validation-summary="ModelOnly"></div>

                        <div class="d-flex flex-column flex-md-row justify-content-between mb-3">
                            <div class="mb-2 mb-md-0 rounded"
                                 style="background-color:#d9edf7;font-weight:400;padding:15px;color:#31708f;">
                                <p class="mb-0">
                                    Tekan Tombol "Simpan Perubahan" untuk menyimpan informasi yang telah diubah
                                </p>
                            </div>

                            <div>
                                <button type="submit" class="btn btn-primary">
                                    Simpan Perubahan
                                </button>
                            </div>
                        </div>

                        <ul class="nav nav-tabs" id="myTab" role="tablist">

                            <li class="nav-item">
                                <a class="nav-link active" data-toggle="tab" href="#pertama">
                                    Identitas Sekolah
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" data-toggle="tab" href="#kedua">
                                    Akreditasi
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" data-toggle="tab" href="#ketiga">
                                    Alamat
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" data-toggle="tab" href="#keempat">
                                    Visi dan Misi
                                </a>
                            </li>

                        </ul>


                        <div class="tab-content" id="myTabContent">

                            <!-- IDENTITAS -->
                            <div class="tab-pane fade show active" id="pertama">

                                <div class="section-title mt-3">
                                    Identitas Sekolah
                                </div>

                                <div class="row">

                                    <div class="col-md-6">

                                        <div class="form-group">
                                            <label asp-for="@Model.NPSN"></label>
                                            <input asp-for="@Model.NPSN" class="form-control" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.NamaSekolah"></label>
                                            <input asp-for="@Model.NamaSekolah" class="form-control" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.BentukPendidikan"></label>
                                            <input asp-for="@Model.BentukPendidikan" class="form-control" />
                                        </div>

                                    </div>


                                    <div class="col-md-6">

                                        <div class="form-group">
                                            <label asp-for="@Model.KepalaSekolah"></label>
                                            <input asp-for="@Model.KepalaSekolah" class="form-control" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.NoHP"></label>
                                            <input asp-for="@Model.NoHP" class="form-control" />
                                        </div>

                                    </div>

                                </div>

                            </div>


                            <!-- AKREDITASI -->
                            <div class="tab-pane fade" id="kedua">

                                <div class="section-title mt-3">
                                    Akreditasi
                                </div>

                                <div class="row">

                                    <div class="col-md-6">

                                        <div class="form-group">
                                            <label asp-for="@Model.Akreditasi"></label>
                                            <input asp-for="@Model.Akreditasi" class="form-control" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.Nilai"></label>
                                            <input asp-for="@Model.Nilai" class="form-control" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.NoSKAkreditasi"></label>
                                            <input asp-for="@Model.NoSKAkreditasi" class="form-control" />
                                        </div>

                                    </div>


                                    <div class="col-md-6">

                                        <div class="form-group">
                                            <label asp-for="@Model.TanggalSKAkreditasi"></label>
                                            <input asp-for="@Model.TanggalSKAkreditasi" class="form-control" type="date" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.TMTMulaiSKAkreditasi"></label>
                                            <input asp-for="@Model.TMTMulaiSKAkreditasi" class="form-control" type="date" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.TMTSelesaiSKAkreditasi"></label>
                                            <input asp-for="@Model.TMTSelesaiSKAkreditasi" class="form-control" type="date" />
                                        </div>

                                    </div>

                                </div>

                            </div>


                            <!-- ALAMAT -->
                            <div class="tab-pane fade" id="ketiga">

                                <div class="section-title mt-3">
                                    Alamat
                                </div>

                                <div class="row">

                                    <div class="col-md-6">

                                        <div class="form-group">
                                            <label asp-for="@Model.Jalan"></label>
                                            <input asp-for="@Model.Jalan" class="form-control" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.DesaKelurahan"></label>
                                            <input asp-for="@Model.DesaKelurahan" class="form-control" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.KecamatanDistrik"></label>
                                            <input asp-for="@Model.KecamatanDistrik" class="form-control" />
                                        </div>

                                    </div>


                                    <div class="col-md-6">

                                        <div class="form-group">
                                            <label asp-for="@Model.KabupatenKota"></label>
                                            <input asp-for="@Model.KabupatenKota" class="form-control" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.Provinsi"></label>
                                            <input asp-for="@Model.Provinsi" class="form-control" />
                                        </div>

                                        <div class="form-group">
                                            <label asp-for="@Model.KodePos"></label>
                                            <input asp-for="@Model.KodePos" class="form-control" />
                                        </div>

                                    </div>

                                </div>

                            </div>


                            <!-- VISI MISI -->
                            <div class="tab-pane fade" id="keempat">

                                <div class="section-title mt-3">
                                    Visi, Misi, & Mars
                                </div>

                                <div class="form-group">
                                    <label asp-for="@Model.Visi"></label>
                                    <textarea asp-for="@Model.Visi" class="form-control editor"></textarea>
                                    <span asp-validation-for="@Model.Visi"></span>
                                </div>

                                <div class="form-group">
                                    <label asp-for="@Model.Misi"></label>
                                    <textarea asp-for="@Model.Misi" class="form-control editor"></textarea>
                                    <span asp-validation-for="@Model.Misi"></span>
                                </div>

                            </div>

                        </div>

                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_CkEditorPartial" />
}