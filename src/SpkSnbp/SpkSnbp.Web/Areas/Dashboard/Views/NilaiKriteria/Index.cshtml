@using SpkSnbp.Web.Areas.Dashboard.Models.NilaiKriteria
@model IndexVM

@inject ITahunAjaranRepository TahunAjaranRepository
@inject IKelasRepository KelasRepository
@inject IKriteriaRepository KriteriaRepository

@{
    ViewData["Title"] = "Nilai Kriteria";
    var daftarTahun = await TahunAjaranRepository.GetAll();
    var daftarKelas = await KelasRepository.GetAll();
    var daftarKriteria = await KriteriaRepository.GetAllActive();
    daftarKriteria = daftarKriteria.Where(x => !x.IsDefault).ToList();
}

<!-- Breadcrumb -->
<div class="row">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="#">Data</a></li>
            <li class="breadcrumb-item"><a asp-action="Index"></a>Kriteria Tambahan</li>
        </ol>
    </nav>
</div>

<!-- Isi Konten -->
<div class="card card-primary">
    <!-- Judul -->
    <div class="card-header">
        <h4>Daftar Kriteria Tambahan</h4>
    </div>
    <div class="padding-20">

        <div class="row mb-3">

            <!-- FILTER -->
            <div class="col-12 col-lg">
                <form asp-action="Index" method="get"
                      class="d-flex flex-column flex-lg-row"
                      style="gap:15px;">

                    <input name="first" id="first" value="False" readonly hidden />

                    <!-- Kriteria -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center" style="gap:8px;">
                        <label asp-for="@Model.Id" class="mb-0 font-weight-bold">Kriteria:</label>
                        <select asp-for="@Model.Id"
                                class="submit-on-change form-control form-control-sm w-100 w-lg-auto"
                                style="min-width:150px;">
                            <option value="@null">-- Pilih Kriteria --</option>
                            @foreach (var item in daftarKriteria)
                            {
                                <option value="@item.Id">@item.Nama</option>
                            }
                        </select>
                    </div>

                    <!-- Tahun -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center" style="gap:8px;">
                        <label asp-for="@Model.Tahun" class="mb-0 font-weight-bold">Tahun Ajaran:</label>
                        <select asp-for="@Model.Tahun"
                                class="submit-on-change form-control form-control-sm w-100 w-lg-auto"
                                style="min-width:150px;">
                            @if (Model.Tahun is null)
                            {
                                <option value="@null">-- Tidak ada Tahun Ajaran --</option>
                            }
                            @foreach (var item in daftarTahun)
                            {
                                <option value="@item.Id">@item.Id</option>
                            }
                        </select>
                    </div>

                    <!-- Jurusan -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center" style="gap:8px;">
                        <label asp-for="@Model.Jurusan" class="mb-0 font-weight-bold">Jurusan:</label>
                        <select asp-for="@Model.Jurusan"
                                class="submit-on-change form-control form-control-sm w-100 w-lg-auto"
                                style="min-width:150px;">
                            @foreach (var item in Enum.GetValues<Jurusan>())
                            {
                                <option value="@item">@item.Humanize()</option>
                            }
                        </select>
                    </div>

                    <!-- Kelas -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center" style="gap:8px;">
                        <label asp-for="@Model.IdKelas" class="mb-0 font-weight-bold">Kelas:</label>
                        <select asp-for="@Model.IdKelas"
                                class="submit-on-change form-control form-control-sm w-100 w-lg-auto"
                                style="min-width:150px;">
                            <option value="@null">-- Semua --</option>
                            @foreach (var item in daftarKelas)
                            {
                                <option value="@item.Id">@item.Nama</option>
                            }
                        </select>
                    </div>

                </form>
            </div>

            @if (Model.Id is not null)
            {
                <!-- TOMBOL -->
                <div class="col-12 col-lg-auto mt-3 mt-lg-0">

                    <div class="row gx-2">
                        <div class="col-6 col-lg-auto pr-1">
                            <a asp-action="DownloadFormat"
                               asp-route-id="@Model.Id"
                               asp-route-tahun="@Model.Tahun"
                               asp-route-jurusan="@Model.Jurusan"
                               asp-route-idKelas="@Model.IdKelas"
                               class="btn btn-icon icon-left btn-danger w-100">
                                <i class="fas fa-file-pdf"></i> Download Format
                            </a>
                        </div>

                        @if (Model.Jurusan is not null && Model.Tahun is not null)
                        {
                            <div class="col-12 col-lg-auto mb-2">
                                <button class="btn btn-tambah btn-icon icon-left btn-primary w-100 w-lg-auto"
                                        data-toggle="tooltip" title="Import Data Dari Excel">
                                    <i class="fas fa-file-import"></i> Import
                                </button>

                                <div class="form-tambah">
                                    <partial name="_FormImportPartial"
                                             model="@(new ImportNilaiKriteriaVM { Id = Model.Id.Value, Tahun = Model.Tahun.Value, Jurusan = Model.Jurusan.Value, IdKelas = Model.IdKelas, ReturnUrl = Context.Request.AbsoluteUri() })" />
                                </div>
                            </div>
                        }

                        <div class="col-6 col-lg-auto pr-1">
                            <a asp-action="PDF"
                               asp-route-id="@Model.Id"
                               asp-route-tahun="@Model.Tahun"
                               asp-route-jurusan="@Model.Jurusan"
                               asp-route-idKelas="@Model.IdKelas"
                               class="btn btn-icon icon-left btn-danger w-100">
                                <i class="fas fa-file-pdf"></i> PDF
                            </a>
                        </div>

                        <div class="col-6 col-lg-auto pl-1">
                            <a asp-action="Excel"
                               asp-route-id="@Model.Id"
                               asp-route-tahun="@Model.Tahun"
                               asp-route-jurusan="@Model.Jurusan"
                               asp-route-idKelas="@Model.IdKelas"
                               class="btn btn-icon icon-left btn-success w-100">
                                <i class="fas fa-file-excel"></i> Excel
                            </a>
                        </div>

                    </div>

                </div>
            }
        </div>

        <form asp-action="Simpan" asp-route-id="@Model.Id" asp-route-jurusan="@Model.Jurusan" asp-route-tahun="@Model.Tahun" asp-route-idKelas="@Model.IdKelas" method="post">
            <!-- EDIT BUTTON -->
            <div class="mb-3">
                <div class="row">
                    <div class="col-12 col-md-auto">
                        <button type="button"
                                id="btnEdit"
                                class="btn btn-icon icon-left btn-warning w-100">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                    </div>
                </div>

                <!-- ACTION BUTTON -->
                <div class="d-none align-items-center" id="actionButtons">

                    <button class="btn btn-icon icon-left btn-primary mr-1"
                            type="submit">
                        <i class="fas fa-save"></i> Simpan
                    </button>

                    <button type="button"
                            id="btnBatal"
                            class="btn btn-icon icon-left btn-danger mr-1">
                        <i class="fas fa-times"></i> Batal
                    </button>

                    <button type="button"
                            id="btnReset"
                            class="btn btn-icon icon-left btn-secondary">
                        <i class="fas fa-undo"></i> Reset
                    </button>

                </div>
            </div>

            @if (Model.Kriteria is not null)
            {
                <div class="table-responsive">
                    <table style="width: 100%" class="table table-striped table-export">
                        <thead>
                            <tr>
                                <th>Nama</th>
                                <th>NISN</th>
                                <th>Jurusan</th>
                                <th>Kelas</th>
                                <th>Tahun Ajaran</th>
                                <th>
                                    <p>@Model.Kriteria.Kode @Model.Kriteria.Nama</p>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.DaftarEntry.Count; i++)
                            {
                                var entry = Model.DaftarEntry[i];
                                <tr>
                                    <input asp-for="@Model.DaftarEntry[@i].IdSiswa" readonly hidden />
                                    <td>@entry.Siswa.Nama</td>
                                    <td>@entry.Siswa.NISN</td>
                                    <td>@entry.Siswa.Jurusan.Humanize()</td>
                                    <td>@entry.Siswa.Kelas.Nama</td>
                                    <td>@entry.Siswa.TahunAjaran.Id</td>
                                    <td>
                                        <input asp-for="@Model.DaftarEntry[@i].Nilai" class="form-control nilai-input" readonly />
                                        <span asp-validation-for="@Model.DaftarEntry[@i].Nilai" class="text-danger"></span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </form>
        <!-- Tabel -->
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        let initialValues = [];

        // EDIT
        document.getElementById("btnEdit").addEventListener("click", function () {

            const inputs = document.querySelectorAll(".nilai-input");

            initialValues = Array.from(inputs).map(el => el.value);

            inputs.forEach(el => {
                el.removeAttribute("readonly");
                el.removeAttribute("disabled");
            });

            const action = document.getElementById("actionButtons");
            action.classList.remove("d-none");
            action.classList.add("d-flex");

            this.style.display = "none";
        });

        // RESET →
        document.getElementById("btnReset").addEventListener("click", function () {
            document.querySelectorAll(".nilai-input").forEach(el => {
                el.value = 0;
            });
        });

        // BATAL
        document.getElementById("btnBatal").addEventListener("click", function () {
            const inputs = document.querySelectorAll(".nilai-input");

            inputs.forEach((el, i) => {
                el.value = initialValues[i];
                el.setAttribute("readonly", true);
            });

            const action = document.getElementById("actionButtons");
            action.classList.add("d-none");
            action.classList.remove("d-flex");

            document.getElementById("btnEdit").style.display = "inline-block";
        });
    </script>

}