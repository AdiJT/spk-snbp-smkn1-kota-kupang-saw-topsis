@using SpkSnbp.Web.Areas.Dashboard.Models.KriteriaModels
@model List<Kriteria>

@{
    ViewData["Title"] = "Kriteria";
}

<!-- Breadcrumb -->
<div class="row">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="#">Beranda</a></li>
            <li class="breadcrumb-item"><a asp-action="Index"></a>Kriteria</li>
        </ol>
    </nav>
</div>

<!-- Isi Konten -->
<div class="card card-primary">
    <!-- Judul -->
    <div class="card-header">
        <h4>Daftar Kriteria</h4>
    </div>
    <div class="padding-20">

        <div class="row mb-3 align-items-center gx-md-0">

            <!-- Tambah Data -->
            <div class="col-12 col-md-auto mb-2 mb-md-0">
                <button class="btn btn-tambah btn-icon icon-left btn-primary w-100 w-md-auto"
                        data-toggle="tooltip" title="Tambah Data Kelas">
                    <i class="fas fa-plus"></i> Tambah Data
                </button>

                <div class="form-tambah">
                    <partial name="_FormTambahPartial" model="@(new TambahVM { ReturnUrl = Context.Request.AbsoluteUri() })" />
                </div>
            </div>

            <!-- PDF -->
            <div class="col-6 col-md-auto ml-auto pr-1">
                <a asp-action="PDF" class="btn btn-icon icon-left btn-danger w-100">
                    <i class="fas fa-file-pdf"></i> PDF
                </a>
            </div>

            <!-- Excel -->
            <div class="col-6 col-md-auto pl-1">
                <a asp-action="Excel" class="btn btn-icon icon-left btn-success w-100">
                    <i class="fas fa-file-excel"></i> Excel
                </a>
            </div>

        </div>

        <!-- Tabel -->
        <div class="table-responsive">
            <table style="width: 100%" class="table table-striped table-export">
                <thead>
                    <tr>
                        <th>Kode</th>
                        <th>Nama</th>
                        <th>Bobot</th>
                        <th>Keterangan Bobot</th>
                        <th>Aktif</th>
                        <th>Jenis</th>
                        <th style="min-width: 130px">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kriteria in Model)
                    {
                        <tr>
                            <td>@kriteria.Kode</td>
                            <td>@kriteria.Nama</td>
                            <td>@((int)kriteria.Bobot)</td>
                            <td>@kriteria.Bobot.ToString().Humanize() - @kriteria.Bobot.Humanize()</td>
                            <td>
                                <form asp-action="SwitchActive" asp-route-id="@kriteria.Id" asp-route-returnUrl="@Context.Request.AbsoluteUri()" style="display:inline" method="post">
                                    @if (kriteria.Active)
                                    {
                                        <button type="submit" class="btn btn-success btn-action">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-danger btn-action">
                                            X
                                        </button>
                                    }
                                </form>
                            </td>
                            <td>@kriteria.Jenis.Humanize()</td>
                            <td>
                                <button class="btn-edit btn btn-primary btn-action">
                                    <i class="fas fa-pencil-alt"></i>
                                </button>
                                <div class="form-edit">
                                    @{
                                        var modelEdit = new EditVM { Id = kriteria.Id, Nama = kriteria.Nama, Bobot = kriteria.Bobot, Jenis = kriteria.Jenis, ReturnUrl = Context.Request.AbsoluteUri() };
                                    }
                                    <partial name="_FormEditPartial" model="@modelEdit" />
                                </div>
                                @if (!kriteria.IsDefault)
                                {
                                    <form asp-action="Hapus" asp-route-id="@kriteria.Id" asp-route-returnUrl="@Context.Request.AbsoluteUri()" style="display:inline" method="post">
                                        <button type="button" class="btn btn-danger btn-action swal-confirm">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}