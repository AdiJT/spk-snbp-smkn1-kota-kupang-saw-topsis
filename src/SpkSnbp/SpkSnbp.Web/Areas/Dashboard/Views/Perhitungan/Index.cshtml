@using SpkSnbp.Domain.Auth
@using SpkSnbp.Web.Areas.Dashboard.Models.Perhitungan
@using SpkSnbp.Web.Authentication
@model IndexVM

@inject ITahunAjaranRepository TahunAjaranRepository
@inject IKriteriaRepository KriteriaRepository
@inject ISignInManager SignInManager
@inject IKelasRepository KelasRepository

@{
    ViewData["Title"] = "Perhitungan";
    var daftarTahun = await TahunAjaranRepository.GetAll();
    var daftarKriteria = await KriteriaRepository.GetAllActive();
    var daftarKelas = await KelasRepository.GetAll();
}

<!-- Breadcrumb -->
<div class="row">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="#">Hasil</a></li>
            <li class="breadcrumb-item"><a asp-action="Index"></a>Perhitungan</li>
        </ol>
    </nav>
</div>

<!-- Isi Konten -->
<div class="card card-primary">
    <!-- Judul -->
    <div class="card-header">
        <h4>Hasil Perhitungan</h4>
    </div>
    <div class="padding-20">

        <div class="row mb-3">

            <!-- FILTER -->
            <div class="col-12 col-lg">
                <form asp-action="Index" method="get"
                      class="d-flex flex-column flex-lg-row"
                      style="gap:15px;">

                    <input name="first" id="first" value="False" readonly hidden />

                    <!-- Tahun -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center" style="gap:8px;">
                        <label asp-for="@Model.Tahun" class="mb-0 font-weight-bold">Tahun Ajaran:</label>
                        <select asp-for="@Model.Tahun"
                                class="submit-on-change form-control form-control-sm w-100 w-lg-auto"
                                style="min-width:150px;">
                            @if (Model.Tahun is null)
                            {
                                <option value="@null">-- Tidak ada Tahun Ajaran --</option>
                            }
                            @foreach (var item in daftarTahun)
                            {
                                <option value="@item.Id">@item.Id</option>
                            }
                        </select>
                    </div>

                    <!-- Jurusan -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center" style="gap:8px;">
                        <label asp-for="@Model.Jurusan" class="mb-0 font-weight-bold">Jurusan:</label>
                        <select asp-for="@Model.Jurusan"
                                class="submit-on-change form-control form-control-sm w-100 w-lg-auto"
                                style="min-width:150px;">
                            @foreach (var item in Enum.GetValues<Jurusan>())
                            {
                                <option value="@item">@item.Humanize()</option>
                            }
                        </select>
                    </div>

                    <!-- Kelas -->
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center" style="gap:8px;">
                        <label asp-for="@Model.IdKelas" class="mb-0 font-weight-bold">Kelas:</label>
                        <select asp-for="@Model.IdKelas"
                                class="submit-on-change form-control form-control-sm w-100 w-lg-auto"
                                style="min-width:150px;">
                            <option value="@null">-- Semua --</option>
                            @foreach (var item in daftarKelas)
                            {
                                <option value="@item.Id">@item.Nama</option>
                            }
                        </select>
                    </div>

                </form>
            </div>


            <!-- BUTTON AREA -->
            <div class="col-12 col-lg-auto mt-3 mt-lg-0">

                <div class="row gx-2">

                    @if (Model.Tahun is not null && Model.DaftarSiswa.Count != 0)
                    {

                        <!-- HITUNG -->
                        <div class="col-6 col-lg-auto mb-2 pr-1">
                            <form asp-action="Hitung"
                                  asp-route-jurusan="@Model.Jurusan"
                                  asp-route-tahun="@Model.Tahun"
                                  asp-route-idKelas="@Model.IdKelas"
                                  class="mb-0">

                                <button class="btn btn-icon icon-left btn-primary w-100 w-lg-auto"
                                        type="submit">
                                    <i class="fas fa-calculator"></i> Hitung
                                </button>

                            </form>
                        </div>

                        <!-- DETAIL -->
                        @if (Model.HasilPerhitungan is not null)
                        {
                            <div class="col-6 col-lg-auto mb-2 pl-1">
                                <button class="btn btn-tambah btn-icon icon-left btn-info w-100 w-lg-auto">
                                    <i class="fas fa-search-plus"></i> Detail
                                </button>

                                <div class="form-tambah">
                                    <partial name="_FormHasilPartial" model="@Model.HasilPerhitungan" />
                                </div>
                            </div>
                        }

                        <!-- PDF -->
                        <div class="col-6 col-lg-auto pr-1">
                            <a asp-action="PDF"
                               asp-route-tahun="@Model.Tahun"
                               asp-route-jurusan="@Model.Jurusan"
                               asp-route-idKelas="@Model.IdKelas"
                               class="btn btn-icon icon-left btn-danger w-100">
                                <i class="fas fa-file-pdf"></i> PDF
                            </a>
                        </div>

                        <!-- EXCEL -->
                        <div class="col-6 col-lg-auto pl-1">
                            <a asp-action="Excel"
                               asp-route-tahun="@Model.Tahun"
                               asp-route-jurusan="@Model.Jurusan"
                               asp-route-idKelas="@Model.IdKelas"
                               class="btn btn-icon icon-left btn-success w-100">
                                <i class="fas fa-file-excel"></i> Excel
                            </a>
                        </div>

                    }
                </div>

            </div>

        </div>

        @if (Model.DaftarSiswa.Any(s => daftarKriteria.Any(k => s.DaftarSiswaKriteria.FirstOrDefault(sk => sk.IdKriteria == k.Id)?.Nilai == null))) 
        {
            <div class="d-flex justify-content-between mb-3">
                <div class="mb-0 card card-body rounded" style="background-color: #d9edf7; font-weight: 400; padding: 15px; color: #31708f;">
                    <p class="mb-0">
                        Perhitungan hanya dapat dilakukan jika setiap data kriteria siswa lengkap!
                        @if (await SignInManager.IsInRole(UserRoles.Admin) == false)
                        {
                            @("Hubungi Admin untuk melengkapi data kriteria siswa");
                        }
                    </p>
                </div>
            </div>
        }

        <div class="table-responsive">
            <table style="width: 100%" class="table table-striped table-export">
                <thead>
                    <tr>
                        @* <th rowspan="2">Rangking</th> *@                        
                        <th rowspan="2">Nama</th>
                        <th rowspan="2">NISN</th>
                        <th rowspan="2">Nilai Preferensi</th>
                        <th colspan="@daftarKriteria.Count">Kriteria</th>
                    </tr>
                    <tr>
                        @foreach (var item in daftarKriteria)
                        {
                            <th>(@item.Kode) @item.Nama</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Tahun is null)
                    {
                        <tr>
                            <td colspan="@(3 + daftarKriteria.Count)">Pilih Tahun Ajaran</td>
                        </tr>
                    }
                    else
                    {
                        var rank = 1;
                        @foreach (var item in Model.DaftarSiswa.OrderByDescending(x => x.NilaiTopsis))
                        {
                            <tr>
                                <td>@item.Nama</td>
                                <td>@item.NISN</td>
                                @if (item.NilaiTopsis is not null)
                                {
                                    <td>@item.NilaiTopsis?.ToString("F3")</td>
                                    rank++;
                                }
                                else
                                {
                                    <td>-</td>
                                }
                                @foreach (var kriteria in daftarKriteria)
                                {
                                    var siswaKriteria = item.DaftarSiswaKriteria.FirstOrDefault(x => x.Kriteria == kriteria);

                                    if (siswaKriteria is not null)
                                    {
                                        if (kriteria.Kode == "C1" || kriteria.Kode == "C2")
                                        {
                                            <td>@siswaKriteria.Nilai.ToString("F2")</td>
                                        }
                                        else if (kriteria.IsDefault)
                                        {
                                            <td>@siswaKriteria.Nilai</td>
                                        }
                                        else
                                        {
                                            <td>@siswaKriteria.Nilai.ToString("F2")</td>
                                        }
                                    }
                                    else
                                    {
                                        <td>-</td>
                                    }
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <!-- Tabel -->
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}